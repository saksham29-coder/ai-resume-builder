# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info

# Virtual environments
.venv

#Environment variables
.env
.env.*

#Workspace files
*.code-workspace

#Ignore everything inside inputs
inputs/*

#Except .gitkeep file
!inputs/.gitkeep

#Ignore everything inside outputs
outputs/*

#Except .gitkeep file
!outputs/.gitkeep

